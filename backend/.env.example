# CBO backend configuration (12-factor). Copy to .env and fill what you have.
# Everything has a runnable embedded default, so the server boots with none of these.

# --- Storage (defaults to embedded SQLite + in-process vector/graph) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/cbo   # enables Postgres adapter
# NEO4J_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=...
# QDRANT_URL=http://localhost:6333
# REDIS_URL=redis://localhost:6379

# --- AI orchestration (defaults to a grounded local reasoner; no hallucination) ---
# LLM_PROVIDER=openai            # openai | anthropic | local (default)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Connector credentials (per-company tokens are passed at connect time too) ---
# GITHUB_TOKEN=ghp_...
# NOTION_TOKEN=secret_...
# SLACK_TOKEN=xoxb-...
# STRIPE_API_KEY=sk_live_...

CORS_ORIGINS=http://localhost:3000
